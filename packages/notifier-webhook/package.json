{
  "name": "@hx2ryu/crashwatch-notifier-webhook",
  "version": "0.1.0-alpha.3",
  "description": "Generic HTTP webhook notifier for crashwatch. Posts JSON alerts to a URL.",
  "keywords": [
    "crashwatch",
    "webhook",
    "notifier",
    "slack"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.tsbuildinfo",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hx2ryu/crashwatch.git",
    "directory": "packages/notifier-webhook"
  },
  "homepage": "https://github.com/hx2ryu/crashwatch/tree/main/packages/notifier-webhook#readme",
  "bugs": {
    "url": "https://github.com/hx2ryu/crashwatch/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@hx2ryu/crashwatch-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
