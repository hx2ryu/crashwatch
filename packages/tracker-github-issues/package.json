{
  "name": "@hx2ryu/crashwatch-tracker-github-issues",
  "version": "0.1.0-alpha.4",
  "description": "GitHub Issues tracker for crashwatch. Opens issues in a GitHub repository when alerts fire.",
  "keywords": [
    "crashwatch",
    "github",
    "issue-tracker"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.tsbuildinfo",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hx2ryu/crashwatch.git",
    "directory": "packages/tracker-github-issues"
  },
  "homepage": "https://github.com/hx2ryu/crashwatch/tree/main/packages/tracker-github-issues#readme",
  "bugs": {
    "url": "https://github.com/hx2ryu/crashwatch/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@hx2ryu/crashwatch-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
