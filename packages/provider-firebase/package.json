{
  "name": "@hx2ryu/crashwatch-provider-firebase",
  "version": "0.1.0-alpha.5",
  "description": "Firebase Crashlytics provider for crashwatch. Reads the Crashlytics BigQuery export — the only officially supported machine-readable source.",
  "keywords": [
    "crashwatch",
    "firebase",
    "crashlytics",
    "bigquery"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.tsbuildinfo",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hx2ryu/crashwatch.git",
    "directory": "packages/provider-firebase"
  },
  "homepage": "https://github.com/hx2ryu/crashwatch/tree/main/packages/provider-firebase#readme",
  "bugs": {
    "url": "https://github.com/hx2ryu/crashwatch/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@hx2ryu/crashwatch-core": "workspace:*",
    "@google-cloud/bigquery": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/bigquery": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
