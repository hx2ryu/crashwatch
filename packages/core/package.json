{
  "name": "@hx2ryu/crashwatch-core",
  "version": "0.1.0-alpha.4",
  "description": "Vendor-neutral core types, config loader, and detection engine for crashwatch.",
  "keywords": [
    "crashwatch",
    "crash-reporting",
    "observability",
    "plugin"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.tsbuildinfo",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hx2ryu/crashwatch.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/hx2ryu/crashwatch/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/hx2ryu/crashwatch/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
