{
  "name": "@hx2ryu/crashwatch-cli",
  "version": "0.1.0-alpha.5",
  "description": "CLI runner for crashwatch: load config, collect, detect, dispatch.",
  "keywords": [
    "crashwatch",
    "cli",
    "crash-reporting"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "crashwatch": "./bin/crashwatch.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "!dist/__tests__",
    "!dist/**/*.tsbuildinfo",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hx2ryu/crashwatch.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/hx2ryu/crashwatch/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/hx2ryu/crashwatch/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hx2ryu/crashwatch-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
