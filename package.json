{
  "name": "crashwatch-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Vendor-neutral, plugin-based crash observability for mobile and backend apps.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hx2ryu/crashwatch.git"
  },
  "homepage": "https://github.com/hx2ryu/crashwatch#readme",
  "bugs": {
    "url": "https://github.com/hx2ryu/crashwatch/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './packages/*' test",
    "lint": "pnpm -r --filter './packages/*' lint",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
